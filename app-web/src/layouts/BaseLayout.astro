---
// Fundations
import "@/styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
// Section
import Footer from "@/components/global/Footer.astro";
import Navbar from "@/components/global/Navbar.astro";
// Hides the  navigation, or footer on selected screens by passing props:
// <BaseLayout hideNavigation={true} hideFooter={true}>
const { hideNavigation = false, hideFooter = false, robots = "index, follow" } = Astro.props;
---

<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead robots={robots} />
  </head>
  <body class="flex flex-col bg-white min-h-dvh">
    {!hideNavigation && <Navbar />}
    <main class="grow"><slot /></main>
    {!hideFooter && <Footer />}

  </body>
</html>
