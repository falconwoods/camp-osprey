---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <main class="prose mx-auto max-w-4xl px-6 py-24">
    <h1>Contact CampSoon</h1>
    <p>For customer support, billing, refund, privacy, or account questions, contact CampSoon by email.</p>

    <h2>Support</h2>
    <p>Email: <a href="mailto:support@campsoon.com">support@campsoon.com</a></p>
    <p>Typical response time: within 2 business days.</p>

    <h2>Billing and Refunds</h2>
    <p>For billing or refund requests, include the email address used for your CampSoon account and any Stripe receipt or payment reference available to you.</p>

    <h2>Business Information</h2>
    <p>Business name: CampSoon</p>
    <p>Website: <a href="https://www.campsoon.com">https://www.campsoon.com</a></p>
  </main>
</BaseLayout>
