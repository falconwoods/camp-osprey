---
import BaseLayout from "@/layouts/BaseLayout.astro";

const installSteps = [
  {
    title: "Download and unzip the package",
    body: "Use only a CampSoon extension package provided through a trusted internal channel, unzip it, and keep the extracted folder somewhere easy to find.",
  },
  {
    title: "Open Chrome Extensions",
    body: "In Chrome, open a new tab and enter chrome://extensions in the address bar.",
  },
  {
    title: "Turn on Developer mode",
    body: "On the Extensions page, enable the Developer mode switch in the top-right corner.",
  },
  {
    title: "Load the unpacked extension",
    body: "Click Load unpacked, then select the extracted CampSoon folder. Select the folder that contains manifest.json, not the ZIP file itself.",
  },
  {
    title: "Pin CampSoon",
    body: "Click the puzzle icon in the Chrome toolbar and pin CampSoon so you can open it quickly.",
  },
];

const checks = [
  "This manual installation flow is retained for historical reference only.",
  "CampSoon no longer distributes extension packages for public manual installation.",
  "Use the Chrome Web Store installation flow for normal installation and updates.",
];
---

<BaseLayout robots="noindex, nofollow">
  <section class="bg-white py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">Historical Manual Installation</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
          Manual CampSoon installation reference
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">
          This page is retained as a historical reference. Public CampSoon installation should use the Chrome Web Store.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <div class="rounded-md bg-slate-900 px-5 py-3 text-sm font-semibold text-white shadow-sm">
            chrome://extensions
          </div>
          <a href="/install" class="text-sm font-semibold text-slate-900 hover:text-blue-600">
            Go to Chrome Web Store install guide
          </a>
        </div>
        <p class="mt-3 text-xs text-slate-500">
          Copy <code class="rounded bg-slate-100 px-1.5 py-0.5 text-slate-700">chrome://extensions</code> into Chrome's address bar. Chrome does not allow this settings page to be opened directly from ordinary web links.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Historical Steps</h2>
      <ol class="mt-8 space-y-4">
        {
          installSteps.map((step, index) => (
            <li class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
              <div class="flex gap-4">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-blue-600 text-sm font-bold text-white">
                  {index + 1}
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-slate-900">{step.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-slate-600">{step.body}</p>
                </div>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Before You Start</h2>
      <ul class="mt-6 space-y-3 text-sm leading-6 text-slate-600">
        {checks.map((check) => <li class="rounded-md bg-slate-50 px-4 py-3">{check}</li>)}
      </ul>
    </div>
  </section>
</BaseLayout>
