---
import BaseLayout from "@/layouts/BaseLayout.astro";

const chromeStoreUrl = "https://chromewebstore.google.com/search/CampSoon";

const installSteps = [
  {
    title: "Open CampSoon in the Chrome Web Store",
    body: "Use the Chrome Web Store button on this page, or search for CampSoon directly in the Chrome Web Store from Chrome on your desktop.",
  },
  {
    title: "Add the extension to Chrome",
    body: "On the CampSoon listing, click Add to Chrome to start the standard Chrome installation flow.",
  },
  {
    title: "Review Chrome's confirmation prompt",
    body: "Review the browser permissions shown by Chrome, then click Add extension to finish installing CampSoon.",
  },
  {
    title: "Pin CampSoon",
    body: "Click the puzzle icon in the Chrome toolbar and pin CampSoon so you can open it quickly.",
  },
];

const checks = [
  "Install CampSoon only from the Chrome Web Store listing.",
  "Chrome Web Store installs are handled by Chrome and receive updates through the browser.",
  "If you cannot find the listing, contact support before installing CampSoon from any unofficial source.",
];
---

<BaseLayout>
  <section class="bg-white py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">Chrome Web Store Installation</p>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
          Install CampSoon from the Chrome Web Store
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">
          The Chrome Web Store is the supported way to install CampSoon. It gives you Chrome's standard install prompt, browser-managed updates, and a safer installation path.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a href={chromeStoreUrl} target="_blank" rel="noreferrer" class="rounded-md bg-blue-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-500">
            Open Chrome Web Store
          </a>
          <a href="mailto:support@campsoon.com" class="text-sm font-semibold text-slate-900 hover:text-blue-600">
            Need help? Contact support
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Installation Steps</h2>
      <ol class="mt-8 space-y-4">
        {
          installSteps.map((step, index) => (
            <li class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
              <div class="flex gap-4">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-blue-600 text-sm font-bold text-white">
                  {index + 1}
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-slate-900">{step.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-slate-600">{step.body}</p>
                </div>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Before You Start</h2>
      <ul class="mt-6 space-y-3 text-sm leading-6 text-slate-600">
        {checks.map((check) => <li class="rounded-md bg-slate-50 px-4 py-3">{check}</li>)}
      </ul>
    </div>
  </section>
</BaseLayout>
