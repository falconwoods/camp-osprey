---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AppIcon from "@/components/assets/AppIcon.astro";

const installSteps = [
  {
    title: "Chrome Web Store listing",
    body: "CampSoon is preparing its public Chrome Web Store listing. The listing URL will be published here when it is approved and available.",
  },
  {
    title: "Install through Chrome",
    body: "After launch, users will install CampSoon through Chrome's standard Add to Chrome flow.",
  },
  {
    title: "Review Chrome's confirmation prompt",
    body: "Chrome will show the extension permissions before installation. Users should review the prompt and continue only if they trust the listing.",
  },
  {
    title: "Pin CampSoon",
    body: "After installation, users can click the puzzle icon in the Chrome toolbar and pin CampSoon for quick access.",
  },
];

const checks = [
  "CampSoon is not yet publicly listed in the Chrome Web Store.",
  "CampSoon does not currently distribute public extension ZIP packages for manual installation.",
  "When CampSoon launches, install it only from the official Chrome Web Store listing.",
];
---

<BaseLayout>
  <section class="bg-white py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="flex flex-col gap-8 sm:flex-row sm:items-start">
        <AppIcon class="size-24 shadow-sm ring-1 ring-slate-200 sm:size-28" size={112} />
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">Chrome Web Store Launch Status</p>
          <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
            CampSoon is preparing for Chrome Web Store release
          </h1>
          <p class="mt-6 text-lg leading-8 text-slate-600">
            CampSoon is not yet publicly available in the Chrome Web Store. After approval and launch, the Chrome Web Store will be the supported way to install CampSoon and receive browser-managed updates.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-4">
            <div class="rounded-md bg-slate-900 px-5 py-3 text-sm font-semibold text-white shadow-sm">
              Chrome Web Store listing coming soon
            </div>
            <a href="mailto:support@campsoon.com" class="text-sm font-semibold text-slate-900 hover:text-blue-600">
              Need help? Contact support
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Expected Installation Flow</h2>
      <ol class="mt-8 space-y-4">
        {
          installSteps.map((step, index) => (
            <li class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
              <div class="flex gap-4">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-blue-600 text-sm font-bold text-white">
                  {index + 1}
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-slate-900">{step.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-slate-600">{step.body}</p>
                </div>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Before You Start</h2>
      <ul class="mt-6 space-y-3 text-sm leading-6 text-slate-600">
        {checks.map((check) => <li class="rounded-md bg-slate-50 px-4 py-3">{check}</li>)}
      </ul>
    </div>
  </section>
</BaseLayout>
