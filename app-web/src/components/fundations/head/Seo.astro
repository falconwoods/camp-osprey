---
const title = "CampSoon - Smart Campsite Availability Monitor for BC Parks";
const description = "Never miss a last-minute cancellation at BC Provincial Parks. Get instant real-time notifications and book your next outdoor adventure effortlessly.";
const canonicalURL = "https://www.campsoon.com";
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={`${canonicalURL}/og-image.jpg`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="CampSoon campsite availability monitor" />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:site_name" content="CampSoon" />
<meta property="og:type" content="website" />
<meta property="og:locale" content="en_CA" />

<meta name="twitter:card" content="summary_large_image" />
