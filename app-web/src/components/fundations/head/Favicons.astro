---
import { withSiteAssetVersion } from "@/config/siteAssets";
---

<!-- Favicons -->
<link rel="icon" type="image/x-icon" href={withSiteAssetVersion("/favicon.ico")} sizes="any" />
<link rel="manifest" href={withSiteAssetVersion("/manifest.webmanifest")} />

<!-- Favicons for different sizes -->
<link rel="icon" type="image/png" sizes="16x16" href={withSiteAssetVersion("/favicon-16x16.png")} />
<link rel="icon" type="image/png" sizes="32x32" href={withSiteAssetVersion("/favicon-32x32.png")} />
<link rel="icon" type="image/png" sizes="48x48" href={withSiteAssetVersion("/favicon-48x48.png")} />

<!-- Apple Touch Icon (for backwards compatibility) -->
<link rel="apple-touch-icon" sizes="180x180" href={withSiteAssetVersion("/apple-touch-icon.png")} />
