---
const POINT_PACKAGES = [
  { id: "small_package", name: "Small Package", points: 1000, priceLabel: "CAD 10" },
  { id: "standard_package", name: "Standard Package", points: 3000, priceLabel: "CAD 25" },
  { id: "value_package", name: "Value Package", points: 5000, priceLabel: "CAD 40" },
];

const details = {
  small_package: {
    note: "Fixed one-time purchase",
    savings: "",
    features: ["1,000 points included", "Enough for 1 successful booking", "Charged only after a campsite is successfully booked"],
  },
  standard_package: {
    note: "Save CAD $5",
    savings: "text-green-600 font-medium",
    features: ["3,000 points included", "Enough for 3 successful bookings", "Charged only after a campsite is successfully booked"],
  },
  value_package: {
    note: "Save CAD $10",
    savings: "text-green-600 font-medium",
    features: ["5,000 points included", "Enough for 5 successful bookings", "Charged only after a campsite is successfully booked"],
  },
};
---

<section id="pricing" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Performance-Based Packages</h2>
      <p class="mt-4 text-lg text-slate-600">Point packages are used for successful campsite bookings. Creating monitors is free, and unused points stay in your balance.</p>
    </div>

    <div class="mx-auto mt-16 grid max-w-sm grid-cols-1 gap-y-10 sm:mt-20 lg:max-w-none lg:grid-cols-3 lg:gap-x-8">
      {
        POINT_PACKAGES.map((pkg) => {
          const isRecommended = pkg.id === "standard_package";
          const pkgDetails = details[pkg.id];
          return (
            <div class={`relative flex flex-col justify-between rounded-3xl bg-white p-8 xl:p-10 ${isRecommended ? "ring-2 ring-blue-600 shadow-md" : "ring-1 ring-slate-200"}`}>
              {isRecommended && (
                <span class="absolute right-6 top-0 -translate-y-1/2 rounded-full bg-blue-600 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white">
                  Most Popular
                </span>
              )}
              <div>
                <h3 class="text-lg font-semibold leading-8 text-slate-900">{pkg.name}</h3>
                <p class="mt-4 text-4xl font-bold tracking-tight text-slate-900">{pkg.priceLabel.replace("CAD ", "CAD $")}</p>
                <p class={`mt-2 text-sm ${pkgDetails.savings || "text-slate-500"}`}>{pkgDetails.note}</p>
                <ul class="mt-8 space-y-3 text-sm leading-6 text-slate-600">
                  {pkgDetails.features.map((feature, index) => (
                    <li class={index === 0 ? "font-semibold text-blue-600" : ""}>&check; {feature}</li>
                  ))}
                </ul>
              </div>
              <p class="mt-8 rounded-md bg-slate-50 px-4 py-3 text-sm font-medium leading-6 text-slate-600">
                Purchase and account management are available inside the CampSoon Chrome extension.
              </p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
