---
const POINT_PACKAGES = [
  { id: "small_package", name: "Small Package", points: 1000, priceLabel: "CAD 10", stripePriceId: "price_1TgDNJDqzvH6lDJeeGBcPzZk" },
  { id: "standard_package", name: "Standard Package", points: 3000, priceLabel: "CAD 25", stripePriceId: "price_1TgDNfDqzvH6lDJeXkSUbu0s" },
  { id: "value_package", name: "Value Package", points: 5000, priceLabel: "CAD 40", stripePriceId: "price_1TgDRADqzvH6lDJezThN1UAs" },
];

const details = {
  small_package: {
    note: "Fixed one-time purchase",
    savings: "",
    features: ["1,000 Points included", "Deducted only on successful assist", "Core monitoring features"],
  },
  standard_package: {
    note: "Save CAD $5",
    savings: "text-green-600 font-medium",
    features: ["3,000 Points included", "Good for 3 successful bookings", "Priority background scanning speed", "Lifetime validity"],
  },
  value_package: {
    note: "Save CAD $10",
    savings: "text-green-600 font-medium",
    features: ["5,000 Points included", "Good for 5 successful bookings", "Multi-camp tracking optimization", "Dedicated email support track"],
  },
};
---

<section id="pricing" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Performance-Based Packages</h2>
      <p class="mt-4 text-lg text-slate-600">Purchase points to activate real-time tracking monitors. Unused points never expire.</p>
    </div>

    <div class="mx-auto mt-16 grid max-w-sm grid-cols-1 gap-y-10 sm:mt-20 lg:max-w-none lg:grid-cols-3 lg:gap-x-8">
      {
        POINT_PACKAGES.map((pkg) => {
          const isRecommended = pkg.id === "standard_package";
          const pkgDetails = details[pkg.id];
          return (
            <div class={`relative flex flex-col justify-between rounded-3xl bg-white p-8 xl:p-10 ${isRecommended ? "ring-2 ring-blue-600 shadow-md" : "ring-1 ring-slate-200"}`}>
              {isRecommended && (
                <span class="absolute right-6 top-0 -translate-y-1/2 rounded-full bg-blue-600 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white">
                  Most Popular
                </span>
              )}
              <div>
                <h3 class="text-lg font-semibold leading-8 text-slate-900">{pkg.name}</h3>
                <p class="mt-4 text-4xl font-bold tracking-tight text-slate-900">{pkg.priceLabel.replace("CAD ", "CAD $")}</p>
                <p class={`mt-2 text-sm ${pkgDetails.savings || "text-slate-500"}`}>{pkgDetails.note}</p>
                <ul class="mt-8 space-y-3 text-sm leading-6 text-slate-600">
                  {pkgDetails.features.map((feature, index) => (
                    <li class={index === 0 ? "font-semibold text-blue-600" : ""}>&check; {feature}</li>
                  ))}
                </ul>
              </div>
              <a
                href="#"
                data-stripe-price-id={pkg.stripePriceId}
                class={`mt-8 block rounded-md px-3 py-2 text-center text-sm font-semibold leading-6 ${isRecommended ? "bg-blue-600 text-white shadow-sm hover:bg-blue-500" : "bg-slate-50 text-slate-900 hover:bg-slate-100"}`}
              >
                Buy Points
              </a>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
