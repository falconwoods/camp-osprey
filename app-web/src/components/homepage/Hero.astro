---
import AppIcon from "@/components/assets/AppIcon.astro";
---

<section class="relative mx-auto max-w-7xl px-6 py-24 text-center lg:px-8">
  <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-6xl">
    Smart Campsite Availability Monitor
  </h1>
  <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-600">
    Tired of manually refreshing for cancelled spots? CampSoon is preparing a Chrome extension that monitors supported park reservation systems, starting with BC Parks, and alerts you when a campsite opens up.
  </p>
  <div class="mt-10 flex items-center justify-center gap-x-6">
    <a href="/install" class="rounded-md bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600">
      View Launch Status
    </a>
    <a href="#features" class="text-sm font-semibold leading-6 text-slate-900">
      Learn how it works <span aria-hidden="true">-&gt;</span>
    </a>
  </div>
  <div class="mt-10 flex items-center justify-center gap-4">
    <AppIcon class="size-16 shadow-sm ring-1 ring-slate-200 sm:size-20" size={80} />
    <div class="text-left">
      <p class="text-sm font-semibold text-slate-900">Look for the CampSoon icon</p>
      <p class="mt-1 text-sm leading-6 text-slate-600">This is the Chrome extension icon after launch.</p>
    </div>
  </div>
</section>
