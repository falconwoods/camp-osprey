---
import Logo from "@/components/assets/Logo.astro";

const navItems = [
  { href: "/#features", text: "Features" },
  { href: "/#pricing", text: "Pricing" },
  { href: "/install", text: "Launch" },
  { href: "/#faq", text: "FAQ" },
];
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8" aria-label="Main navigation">
    <a href="/" class="text-lg font-bold text-slate-900">
      <Logo />
    </a>
    <div class="flex items-center gap-6">
      {
        navItems.map((item) => (
          <a href={item.href} class="text-sm font-semibold text-slate-700 hover:text-blue-600">
            {item.text}
          </a>
        ))
      }
    </div>
  </nav>
</header>
